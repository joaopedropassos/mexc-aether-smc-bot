# ======================================================
# MEXC AETHER SMC BOT - ENVIRONMENT VARIABLES
# ======================================================
# 1. Copy this file to .env
# 2. NEVER commit .env or share your keys
# 3. For MEXC Futures (USDT Perpetual / Swap):
#    - Create API key at https://www.mexc.com/user/api (or Futures section)
#    - Enable "Futures Trading" / "Order Placement" permissions
#    - Bind IP address if possible (recommended for production)
#    - Use separate keys for test if available
#
# Example from your provided file (replace with yours):
# MEXC_API_KEY=mx0vgluRtZgfoCtwFH
# MEXC_API_SECRET=b38338a4be8d456ea5e9d14d1fd5b409

MEXC_API_KEY=your_mexc_api_key_here
MEXC_API_SECRET=your_mexc_api_secret_here

# ======================================================
# X (Twitter) API for Sentiment Module (OPTIONAL)
# ======================================================
# To enable x_sentiment, you need X API v2 Bearer Token (Essential or higher access).
# Get at https://developer.twitter.com
# If not configured or ENABLE_X_SENTIMENT=false, the module is skipped gracefully.
X_BEARER_TOKEN=your_x_bearer_token_here_optional

# ======================================================
# Optional overrides (advanced)
# ======================================================
# LOG_LEVEL=INFO

# --- REAL TRADER MODE (DANGEROUS) ---
# Set to false ONLY after extensive paper trading and you understand the risks.
# When false, the bot will place REAL orders on the exchange with real money.
# DRY_RUN=false

# For stocks (ações) and commodities (comodites) via other brokers (future extension)
# Example for Alpaca (US stocks):
# ALPACA_API_KEY=...
# ALPACA_SECRET=...

# yfinance is used for volume ranking of stocks/commodities (free, real data, no API key needed)
